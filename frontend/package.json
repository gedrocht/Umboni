{
  "name": "umboni-weather-visualizer",
  "version": "0.1.0",
  "private": true,
  "description": "Angular visualization application for the Umboni weather platform.",
  "scripts": {
    "start": "ng serve",
    "build": "ng build",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "validate": "npm run lint && npm run test && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "@angular/common": "latest",
    "@angular/compiler": "latest",
    "@angular/core": "latest",
    "@angular/forms": "latest",
    "@angular/platform-browser": "latest",
    "@angular/platform-browser-dynamic": "latest",
    "@angular/router": "latest",
    "rxjs": "latest",
    "tslib": "latest",
    "zone.js": "latest"
  },
  "devDependencies": {
    "@angular/build": "latest",
    "@angular/cli": "latest",
    "@angular/compiler-cli": "latest",
    "@eslint/js": "latest",
    "@playwright/test": "latest",
    "@types/node": "latest",
    "@vitest/coverage-v8": "latest",
    "angular-eslint": "latest",
    "eslint": "latest",
    "jsdom": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vitest": "latest"
  }
}
