{
  "name": "umboni-weather-visualizer",
  "version": "0.1.0",
  "private": true,
  "description": "Angular visualization application for the Umboni weather platform.",
  "scripts": {
    "start": "ng serve",
    "build": "ng build",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "validate": "npm run lint && npm run test && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "@angular/common": "21.2.5",
    "@angular/compiler": "21.2.5",
    "@angular/core": "21.2.6",
    "@angular/forms": "21.2.5",
    "@angular/platform-browser": "21.2.5",
    "@angular/platform-browser-dynamic": "21.2.5",
    "@angular/router": "21.2.5",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.1"
  },
  "devDependencies": {
    "@angular/build": "21.2.3",
    "@angular/cli": "21.2.3",
    "@angular/compiler-cli": "21.2.5",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.58.2",
    "@types/node": "25.5.0",
    "@vitest/coverage-v8": "4.1.0",
    "angular-eslint": "21.3.1",
    "eslint": "10.0.3",
    "jsdom": "29.0.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.1",
    "vitest": "4.1.0"
  },
  "overrides": {
    "undici": "7.24.4"
  }
}
