{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "umboni-weather-visualizer": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "source",
      "prefix": "umboni",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/umboni-weather-visualizer",
            "index": "source/index.html",
            "browser": "source/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "source/styles.css"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kb",
                  "maximumError": "1mb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "umboni-weather-visualizer:build:production"
            },
            "development": {
              "buildTarget": "umboni-weather-visualizer:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}

